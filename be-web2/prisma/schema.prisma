generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          Int           @id @default(autoincrement())
  nama        String
  location    String
  dateEvent   DateTime      @map("date_event")
  description String        @db.Text
  categoryId  Int           @map("category_id")
  speakerId   Int           @map("speaker_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  category    CategoryEvent @relation(fields: [categoryId], references: [id])
  speaker     Speaker       @relation(fields: [speakerId], references: [id])

  @@map("events")
}

model CategoryEvent {
  id          Int     @id @default(autoincrement())
  nama        String
  description String  @db.Text
  events      Event[]

  @@map("category_event")
}

model Speaker {
  id      Int     @id @default(autoincrement())
  nama    String
  materi  String? @db.Text
  jabatan String
  foto    String? // Dibuat opsional agar tidak crash saat create jika belum ada foto
  events  Event[]

  @@map("speakers")
}

model User {
  id       Int    @id @default(autoincrement())
  nim      String @unique
  password String
  nama     String

  @@map("users")
}