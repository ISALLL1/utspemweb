generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id            Int           @id @default(autoincrement())
  nama          String
  location      String
  dateEvent     DateTime      @map("date_event")
  description   String        @db.Text
  categoryId    Int           @map("category_id")
  
  // Ini adalah bagian terpenting agar sesuai dengan kolom 'speaker_id' di Supabase
  pembicaraId   Int           @map("speaker_id") 
  
  createdAt     DateTime      @default(now()) @map("created_at")
  category      CategoryEvent @relation(fields: [categoryId], references: [id])
  pembicara     Pembicara     @relation(fields: [pembicaraId], references: [id])

  @@map("events")
}

model CategoryEvent {
  id          Int      @id @default(autoincrement())
  nama        String
  description String   @db.Text
  events      Event[]

  @@map("category_event")
}

model Pembicara {
  id      Int      @id @default(autoincrement())
  nama    String
  materi  String?  @db.Text
  jabatan String
  foto    String?
  events  Event[]

  @@map("speakers")
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String?

  @@map("users")
}